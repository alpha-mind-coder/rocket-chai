<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="/admin.css" />
</head>
<body>
  <h2>Admin Dashboard</h2>

  <% if (orders.length === 0) { %>
    <p>No orders yet.</p>
  <% } else { %>
    <table class="order-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Student ID</th>
          <th>Phone</th>
          <th>Email</th>
          <th>Quantity</th>
          <th>Items</th>
          <th>Payment Screenshot</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% orders.forEach((order, index) => { %>
          <tr>
            <td><%= index + 1 %></td>
            <td><%= order.name || "N/A" %></td>
            <td><%= order.student_id || "N/A" %></td>
            <td><%= order.phone || "N/A" %></td>
            <td><%= order.email || "N/A" %></td>
            <td><%= order.quantity || 0 %></td>
            <td>
              <ul>
                <% 
                let items = [];
                try {
                  items = JSON.parse(order.item);
                } catch(e) {}
              %>
                <% for (const [itemName, details] of Object.entries(items)) { %>
                  <li><strong><%= itemName %></strong> - Qty: <%= details.quantity %>, ₹<%= details.price %></li>
                <% } %>
              </ul>
            </td>
            <td>
              <% if (order.screenshot_url) { %>
                <img src="<%= order.screenshot_url %>" alt="Screenshot" class="thumb-img" />
              <% } else { %>
                <em>No screenshot</em>
              <% } %>
            </td>
             <td>
              <button class="delete-order-btn" data-id="<%= order._id %>">Delete</button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const deleteButtons = document.querySelectorAll(".delete-order-btn");

    deleteButtons.forEach(button => {
      button.addEventListener("click", () => {
        const orderId = button.getAttribute("data-id");
        if (confirm("Are you sure you want to delete this order?")) {
          fetch(`/admin/orders/${orderId}`, {
            method: "DELETE",
            headers: {
              "Content-Type": "application/json"
            }
          })
          .then(res => {
            if (res.ok) {
              // Remove the row from table
              button.closest("tr").remove();
            } else {
              alert("Failed to delete order.");
            }
          })
          .catch(() => alert("Error deleting order."));
        }
      });
    });
  });
</script>
</body>
</html>
