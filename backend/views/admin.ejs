<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="/admin.css" />
</head>
<body>
  <h2>Admin Dashboard</h2>

  <% if (orders.length === 0) { %>
    <p>No orders yet.</p>
  <% } else { %>
    <table class="order-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Student ID</th>
          <th>Phone</th>
          <th>Email</th>
          <th>Quantity</th>
          <th>Items</th>
          <th>Payment Screenshot</th>
        </tr>
      </thead>
      <tbody>
        <% orders.forEach((order, index) => { %>
          <tr>
            <td><%= index + 1 %></td>
            <td><%= order.name || "N/A" %></td>
            <td><%= order.student_id || "N/A" %></td>
            <td><%= order.phone || "N/A" %></td>
            <td><%= order.email || "N/A" %></td>
            <td><%= order.quantity || 0 %></td>
            <td>
              <% 
                let items = [];
                try {
                  items = JSON.parse(order.item);
                } catch(e) {}
              %>
              <ul>
                <% for (const [itemName, details] of Object.entries(items)) { %>
                  <li><strong><%= itemName %></strong> - Qty: <%= details.quantity %>, ₹<%= details.price %></li>
                <% } %>
              </ul>
            </td>
            <td>
              <% if (order.screenshot_url) { %>
                <img src="<%= order.screenshot_url %>" alt="Screenshot" class="thumb-img" />
              <% } else { %>
                <em>No screenshot</em>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</body>
</html>
